# ============================================================
# Dr.Clash — Backend Environment Variables
# Copy this file to .env and fill in your values.
# Everything here stays on your machine / gets deployed as
# Cloudflare Workers secrets. NEVER commit .env to git.
# ============================================================

# ---------- CLOUDFLARE ----------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ---------- WORKERS API ----------
JWT_SECRET=

# ---------- GOOGLE OAUTH ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://drclash-api.workers.dev/api/auth/google/callback

# ---------- RESEND (Email) ----------
RESEND_API_KEY=
RESEND_SENDER_EMAIL=

# ---------- ADMIN ACCOUNT ----------
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ---------- APP ----------
APP_URL=
