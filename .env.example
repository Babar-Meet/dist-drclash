# ============================================================
# Dr.Clash — Backend Environment Variables
# Copy this file to .env and fill in your values.
# Everything here stays on your machine / gets deployed as
# Cloudflare Workers secrets. NEVER commit .env to git.
# ============================================================

# ---------- CLOUDFLARE ----------
# Your Cloudflare Account ID (find it in your Cloudflare dashboard
# right sidebar after logging in at dash.cloudflare.com)
# Looks like: abc123def456abc123def456abc123def456
CLOUDFLARE_ACCOUNT_ID=

# ---------- WORKERS API ----------
# A random secret string used to sign login tokens (JWT).
# Generate one here: https://1password.com/password-generator/
# Use at least 32 random characters.
JWT_SECRET=

# ---------- GOOGLE OAUTH ----------
# From Google Cloud Console (console.cloud.google.com):
# Create OAuth Client ID (Web Application), then paste below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# The redirect URI you set in Google Cloud Console.
# Default: https://drclash-api.workers.dev/api/auth/google/callback
GOOGLE_CALLBACK_URL=https://drclash-api.workers.dev/api/auth/google/callback

# ---------- RESEND (Email) ----------
# For password reset emails. Sign up at resend.com, create an API key.
RESEND_API_KEY=
# The verified sender email address from Resend.
# Default looks like: noreply@resend.dev
RESEND_SENDER_EMAIL=

# ---------- ADMIN ACCOUNT ----------
# Your personal admin credentials to access /admin dashboard.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ---------- APP ----------
# Your live website URL (no trailing slash).
APP_URL=
